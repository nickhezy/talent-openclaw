{
  "id": "openclaw",
  "name": "OpenClaw Gateway Agent",
  "version": "1.0.0",
  "role": "Engineer",
  "hosting": "company",
  "settings": {
    "sections": [
      {
        "id": "connection",
        "title": "Connection",
        "fields": [
          {"key": "openclaw_bin", "type": "text", "label": "openclaw binary path", "default": "openclaw"}
        ]
      },
      {
        "id": "channels",
        "title": "Channel Credentials",
        "fields": [
          {"key": "telegram_bot_token", "type": "secret", "label": "Telegram Bot Token"},
          {"key": "discord_bot_token", "type": "secret", "label": "Discord Bot Token"},
          {"key": "slack_app_token", "type": "secret", "label": "Slack App Token (xapp-...)"},
          {"key": "slack_bot_token", "type": "secret", "label": "Slack Bot Token (xoxb-...)"}
        ]
      },
      {
        "id": "voice",
        "title": "Voice & Search",
        "fields": [
          {"key": "elevenlabs_api_key", "type": "secret", "label": "ElevenLabs API Key (TTS)"},
          {"key": "brave_api_key", "type": "secret", "label": "Brave Search API Key"}
        ]
      }
    ]
  },
  "prompts": {
    "skills": ["skills/*/SKILL.md"]
  },
  "tools": {
    "builtin": [],
    "custom": []
  },
  "platform_capabilities": ["websocket"],
  "heartbeat": {"method": "always_online"}
}
